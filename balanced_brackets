def is_balanced(s):
    stack = []

    pairs = {
        ')': '(',
        ']': '[',
        '}': '{'
    }

    for char in s:
        if char in "([{":
            stack.append(char)
      
        elif char in ")]}":
        
            if len(stack) == 0:
                return False

            top = stack.pop()

            if top != pairs[char]:
                return False

    return len(stack) == 0
